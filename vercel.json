  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/dashboard", "destination": "/admin/dashboard.html" },
    { "source": "/admin/speakers", "destination": "/admin/speakers.html" },
    { "source": "/admin/organizers", "destination": "/admin/organizers.html" },
