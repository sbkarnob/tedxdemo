    { "source": "/admin/sponsors", "destination": "/admin/sponsors.html" },
    { "source": "/admin/schedule", "destination": "/admin/schedule.html" },
    { "source": "/admin/messages", "destination": "/admin/messages.html" },
    { "source": "/admin/event", "destination": "/admin/event.html" },
    { "source": "/admin/settings", "destination": "/admin/settings.html" },
